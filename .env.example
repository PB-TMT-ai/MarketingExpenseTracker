# ─────────────────────────────────────────────────────────────────────────────
# Server-only secrets. NEVER prefix any of these with NEXT_PUBLIC_ — that ships
# the value into the browser bundle. These are read only on the server.
# Copy this file to `.env.local` (gitignored) and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# Shared password that gates the entire app. The /login form checks against this.
# Choose any value for local dev.
APP_PASSWORD=change-me

# Secret used to sign the session JWT cookie (jose HS256). MUST be >= 32 random bytes.
# Generate one with either:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Database connection (the single local↔cloud seam).
#   Local (default): the embedded PGlite on-disk path — no cloud needed to run.
#   Supabase (deploy): the POOLED transaction-mode string (host contains -pooler, port :6543)
#   and it MUST include ?sslmode=require so the connection is TLS-encrypted, e.g.:
#   postgresql://USER:PASSWORD@HOST-pooler.REGION.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=./.pglite
