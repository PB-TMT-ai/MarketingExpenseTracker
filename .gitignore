# Brainstorm visual-companion scratch (not part of the project)
.superpowers/

# Local env / secrets
.env
.env*.local

# Node / Next.js (populated when the app is scaffolded in Phase 1)
node_modules/
.next/
/out/

# Local embedded Postgres (PGlite on-disk data dir) — never commit local DB state
.pglite/
.pglite

# TypeScript / Next typegen (auto-generated, regenerated on build)
*.tsbuildinfo
next-env.d.ts

# Local dev server log (debug scratch)
.dev.log

# Playwright outputs (HTML report, traces, screenshots on failure)
/test-results/
/playwright-report/
/playwright/.cache/
.gstack/
.design-audit-*/

# Transient agent worktrees (GSD executor isolation)
.claude/worktrees/
